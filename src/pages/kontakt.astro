---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt" description="Kontakt zu Cash and Code für Feedback, Themenideen und Kooperationen.">
  <main>
    <section class="page-title">
      <div class="container">
        <p class="eyebrow">Kontakt</p>
        <h1>Feedback, Fragen oder Themenideen?</h1>
        <p class="lead">
          Schreibt uns – ob Feedback zu einer Folge, ein Themenvorschlag oder eine Kooperationsidee.
        </p>
        <div class="actions">
          <a class="button" href="mailto:podcast@cashandcode.show">podcast@cashandcode.show</a>
        </div>
        <p style="margin-top: 20px; color: var(--muted); font-size: 0.9rem;">
          Oder per DM auf LinkedIn:
          <a href="https://www.linkedin.com/in/sebastiansteiner-schwarzwald/">Sebastian</a>
          &amp;
          <a href="https://www.linkedin.com/in/mariusobert/">Marius</a>
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
