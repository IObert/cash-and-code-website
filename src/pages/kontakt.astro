---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt" description="Kontakt zu Cash and Code für Feedback, Themenideen und Kooperationen.">
  <main>
    <section class="page-title">
      <div class="container">
        <p class="eyebrow">Kontakt</p>
        <h1>Feedback, Fragen oder Themenideen?</h1>
        <p class="lead">
          Schreibt uns, wenn ihr eine Folge diskutieren, ein Thema vorschlagen oder mit uns in Kontakt treten wollt.
        </p>
        <div class="actions">
          <a class="button" href="mailto:sebastian@cashandcode.show">E-Mail Sebastian</a>
          <a class="button secondary" href="mailto:marius@cashandcode.show">E-Mail Marius</a>
          <a class="button secondary" href="https://www.linkedin.com/in/sebastian-steiner-75026b248/">LinkedIn Sebastian</a>
          <a class="button secondary" href="https://www.linkedin.com/in/mariusobert/">LinkedIn Marius</a>
          <a class="button secondary" href="https://open.spotify.com/show/0pVDQxkINI9yB9MDhmuTqN">Spotify öffnen</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
