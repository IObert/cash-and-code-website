---
import "../styles.css";
import { withBase } from "../utils/withBase";

interface Props {
  title: string;
  description: string;
  image?: string;
  titleSuffix?: boolean;
}

const { title, description, image = "/cash-and-code-cover.jpg", titleSuffix = true } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site || "https://cashandcode.show");
const pageTitle = titleSuffix && !title.includes("Podcast") ? `${title} · Cash and Code Podcast` : title;
const nav = [
  ["Folgen", "/folgen/"],
  ["Themen", "/themen/"],
  ["Über uns", "/ueber-uns/"],
  ["Kontakt", "/kontakt/"],
];
const spotifyUrl = "https://open.spotify.com/show/0pVDQxkINI9yB9MDhmuTqN";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/home.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/home.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(withBase(image), canonical)} />
    <meta property="og:locale" content="de_DE" />
    <script is:inline>
      (() => {
        const key = "cash-and-code-theme";
        const stored = localStorage.getItem(key);
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored || (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav">
          <a class="brand" href={withBase("/")}>
            <span class="brand-mark">
              <img src="/home.png" alt="Cash and Code Logo" width="40" height="40" />
            </span>
            <span>Cash and Code <strong>Podcast</strong></span>
          </a>
          <div class="nav-actions">
            <nav class="nav-links" aria-label="Hauptnavigation">
              {nav.map(([label, href]) => (
                <a href={withBase(href)} aria-current={Astro.url.pathname.endsWith(href) ? "page" : undefined}>{label}</a>
              ))}
              <a href={spotifyUrl} title="Zum Podcast auf Spotify" aria-label="Zum Podcast auf Spotify" class="nav-spotify">
                <svg viewBox="0 0 24 24" role="img" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3c-2.2 0-4 1.8-4 4v6c0 2.2 1.8 4 4 4s4-1.8 4-4V7c0-2.2-1.8-4-4-4" />
                  <path d="M7 13a5 5 0 0 0 10 0" />
                  <path d="M12 17v3" />
                  <path d="M9 20h6" />
                </svg>
                <span>Zum Podcast</span>
              </a>
            </nav>
            <button class="theme-toggle" type="button" aria-label="Zu Dunkelmodus wechseln" data-theme-toggle>
              <span class="theme-icon" data-theme-icon="moon" aria-hidden="true">
                <svg viewBox="0 0 24 24" role="img" focusable="false">
                  <path d="M20 15.2A8.8 8.8 0 0 1 8.8 4a8.9 8.9 0 1 0 11.2 11.2Z" />
                </svg>
              </span>
              <span class="theme-icon" data-theme-icon="sun" aria-hidden="true" hidden>
                <svg viewBox="0 0 24 24" role="img" focusable="false">
                  <circle cx="12" cy="12" r="4" />
                  <path d="M12 2v3" />
                  <path d="M12 19v3" />
                  <path d="M2 12h3" />
                  <path d="M19 12h3" />
                  <path d="m4.9 4.9 2.2 2.2" />
                  <path d="m16.9 16.9 2.2 2.2" />
                  <path d="m19.1 4.9-2.2 2.2" />
                  <path d="m7.1 16.9-2.2 2.2" />
                </svg>
              </span>
            </button>
          </div>
        </div>
      </header>
      <slot />
      <footer class="site-footer">
        <div class="container footer-row">
          <span>© {new Date().getFullYear()} Cash and Code</span>
          <span>
            <a href={withBase("/impressum/")}>Impressum</a> · <a href={withBase("/datenschutz/")}>Datenschutz</a> · <a href={withBase("/disclaimer/")}>Disclaimer</a>
          </span>
        </div>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const key = "cash-and-code-theme";
        const root = document.documentElement;
        const button = document.querySelector("[data-theme-toggle]");
        if (!button) return;
        const moonIcon = button.querySelector('[data-theme-icon="moon"]');
        const sunIcon = button.querySelector('[data-theme-icon="sun"]');

        const setLabel = (theme) => {
          const isDark = theme === "dark";
          button.setAttribute("aria-label", isDark ? "Zu Hellmodus wechseln" : "Zu Dunkelmodus wechseln");
          if (moonIcon) moonIcon.toggleAttribute("hidden", isDark);
          if (sunIcon) sunIcon.toggleAttribute("hidden", !isDark);
        };

        const current = root.getAttribute("data-theme") || "light";
        setLabel(current);

        button.addEventListener("click", () => {
          const next = (root.getAttribute("data-theme") || "light") === "dark" ? "light" : "dark";
          root.setAttribute("data-theme", next);
          localStorage.setItem(key, next);
          setLabel(next);
        });
      })();
    </script>
  </body>
</html>
