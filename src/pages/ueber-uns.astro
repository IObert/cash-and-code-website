---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { AuthorCard } from "../components/AuthorCard";
import { withBase } from "../utils/withBase";

const authorsRaw = await getCollection("authors");
const authors = authorsRaw.sort((a, b) => {
  if (a.data.name.includes("Sebastian")) return -1;
  if (b.data.name.includes("Sebastian")) return 1;
  return 0;
});
---

<BaseLayout title="Über uns" description="Über Sebastian Steiner, Marius Obert und die Idee hinter Cash and Code.">
  <main>
    <section class="page-title">
      <div class="container">
        <p class="eyebrow">Über uns</p>
        <h1>Aus privaten Telefonaten wurde ein Podcast.</h1>
        <p class="lead">
          Sebastian und Marius kennen sich seit Jahrzehnten. Was als energische Diskussionen beim Telefonieren begann –
          Finanzwelt trifft Tech, Bankpraxis trifft Softwareentwicklung – wurde irgendwann zu groß für private Gespräche.
          Also haben sie die Hörer einfach mitgenommen.
        </p>
      </div>
    </section>
    <section class="section compact">
      <div class="container grid two">
        {authors.map((author) => (
          <AuthorCard
            name={author.data.name}
            role={author.data.role}
            image={author.data.image ? withBase(author.data.image) : undefined}
            body={author.body}
            links={author.data.links}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
